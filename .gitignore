# --- Secrets / environment ---
.env
.env.*
!.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/

# --- Virtual environments ---
.venv/
venv/
env/

# --- Testing / tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# --- Logs ---
logs/*.log
logs/*.log.zip

# --- Generated output (JSON/Excel exports) ---
output/json/*
output/excel/*
!output/json/.gitkeep
!output/excel/.gitkeep

# --- Playwright ---
# Browser binaries are downloaded per-machine via `playwright install`;
# never commit them.
.playwright/
ms-playwright/

# --- Editors / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Alembic ---
# Migration *files* under migrations/versions/ ARE committed (they're
# schema history, not generated noise) — only local sqlite fallback DBs
# some setups create are excluded here, if ever present.
*.sqlite3
