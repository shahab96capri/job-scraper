# --- Application ---
APP_ENV=development
APP_NAME=Iran Job Intelligence Platform
DEBUG=true

# --- Database (PostgreSQL only) ---
DATABASE_URL=postgresql+asyncpg://job_platform_user:change_me@localhost:5432/job_intelligence
DATABASE_URL_SYNC=postgresql+psycopg2://job_platform_user:change_me@localhost:5432/job_intelligence
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Crawling ---
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
REQUEST_DELAY_SECONDS=2.0
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=5.0
MAX_CONCURRENT_SPIDERS=2

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATION=10 MB
LOG_RETENTION=14 days

# --- Output ---
OUTPUT_JSON_DIR=output/json
OUTPUT_EXCEL_DIR=output/excel
